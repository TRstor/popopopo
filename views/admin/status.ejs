<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>حالة الخدمة - Linkin1</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="admin-logo"><i class="fas fa-shield-alt"></i> إدارة Linkin1</div>
            <nav>
                <a href="/admin"><i class="fas fa-chart-bar"></i> الرئيسية</a>
                <a href="/admin/merchants"><i class="fas fa-users"></i> التجار</a>
                <a href="/admin/tickets"><i class="fas fa-headset"></i> التذاكر</a>
                <a href="/admin/notifications"><i class="fas fa-bell"></i> الإشعارات</a>
                <a href="/admin/status" class="active"><i class="fas fa-server"></i> حالة الخدمة</a>
                <a href="/dashboard"><i class="fas fa-arrow-right"></i> لوحة التحكم</a>
            </nav>
        </aside>
        <main class="admin-main">
            <h1>حالة الخدمة</h1>
            <div class="status-grid">
                <div class="status-card">
                    <div class="status-indicator online"></div>
                    <div>
                        <strong>الخادم</strong>
                        <small>يعمل بشكل طبيعي</small>
                    </div>
                </div>
                <div class="status-card">
                    <div class="status-indicator online"></div>
                    <div>
                        <strong>قاعدة البيانات</strong>
                        <small>متصلة</small>
                    </div>
                </div>
            </div>
            <div class="info-grid">
                <div class="info-card">
                    <span class="info-label">وقت التشغيل</span>
                    <span class="info-value"><%= status.uptime %></span>
                </div>
                <div class="info-card">
                    <span class="info-label">استهلاك الذاكرة</span>
                    <span class="info-value"><%= status.memory %></span>
                </div>
                <div class="info-card">
                    <span class="info-label">إصدار Node.js</span>
                    <span class="info-value"><%= status.nodeVersion %></span>
                </div>
                <div class="info-card">
                    <span class="info-label">النظام</span>
                    <span class="info-value"><%= status.platform %></span>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
