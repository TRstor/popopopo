<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= merchant.store_name %></title>
    <meta name="description" content="<%= merchant.store_desc || merchant.store_name %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/theme-<%= merchant.theme_style || 'dark' %>.css">
</head>
<body>
    <div class="profile-page">
        <div class="brand-top">
            <span>Link<span class="brand-highlight">in1</span></span>
        </div>

        <div class="profile-card">
            <div class="profile-avatar">
                <% if (merchant.profile_image) { %>
                    <img src="<%= merchant.profile_image %>" alt="<%= merchant.store_name %>">
                <% } else { %>
                    <div class="avatar-placeholder">
                        <i class="fas fa-store"></i>
                    </div>
                <% } %>
            </div>
            <h1 class="profile-name"><%= merchant.store_name %></h1>
            <% if (merchant.store_desc) { %>
                <p class="profile-desc"><%= merchant.store_desc %></p>
            <% } %>
            <div class="profile-badge"><i class="fas fa-check-circle"></i> اجمع كل روابطك في صفحة واحدة</div>
        </div>

        <div class="links-container">
            <% links.filter(l => l.is_active).forEach(link => { %>
                <a href="<%= link.url %>" class="profile-link size-<%= link.size || 'full' %>" target="_blank" rel="noopener noreferrer" data-bg="<%= link.color %>">
                    <i class="<%= link.icon %>"></i>
                    <span><%= link.title %></span>
                </a>
            <% }) %>
        </div>

        <div class="powered-by">
            <a href="/">Linkin1</a>
        </div>
    </div>
    <script>document.querySelectorAll('[data-bg]').forEach(el => el.style.background = el.dataset.bg);</script>
</body>
</html>
