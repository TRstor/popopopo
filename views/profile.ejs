<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= merchant.store_name %></title>
    <meta name="description" content="<%= merchant.store_desc || merchant.store_name %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Cairo:wght@400;600;700;800&family=Almarai:wght@400;700;800&family=Changa:wght@400;600;700;800&family=Readex+Pro:wght@400;600;700&family=Noto+Kufi+Arabic:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/theme-<%= merchant.theme_style || 'dark' %>.css">
    <% const hasSallaWidget = (products || []).some(p => p.salla_store_id && p.salla_product_id); %>
    <% if (hasSallaWidget) { %>
    <script type="module" src="https://cdn.assets.salla.network/prod/@salla.sa/fast-checkout-widget/v0.0.25/widget.esm.js"></script>
    <% } %>
    <style>
        body { font-family: '<%= merchant.font_family || "Tajawal" %>', sans-serif; }
        <% if (merchant.font_size === 'small') { %>
        .profile-name { font-size: 17px; }
        .profile-desc { font-size: 12px; }
        .profile-link span { font-size: 12px; }
        <% } else if (merchant.font_size === 'large') { %>
        .profile-name { font-size: 24px; }
        .profile-desc { font-size: 15px; }
        .profile-link span { font-size: 16px; }
        <% } %>
        <% if (merchant.bg_image) { %>
        body { background-image: url('<%= merchant.bg_image %>'); background-size: cover; background-position: center; background-attachment: fixed; }
        body::before { content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 0; }
        .profile-page { position: relative; z-index: 1; }
        <% } %>
    </style>
</head>
<body>
    <% if (typeof isPreview !== 'undefined' && isPreview) { %>
    <div class="preview-banner" style="position:fixed;top:0;left:0;right:0;z-index:9999;background:#8B5CF6;color:#fff;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;font-size:14px;font-family:Tajawal,sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.3)">
        <span><i class="fas fa-eye" style="margin-left:6px"></i> وضع المعاينة — هذا ما يراه الزوار</span>
        <a href="/dashboard" style="color:#fff;background:rgba(255,255,255,0.2);padding:5px 12px;border-radius:20px;text-decoration:none;font-size:13px"><i class="fas fa-arrow-right" style="margin-left:4px"></i> العودة للوحة</a>
    </div>
    <style>body { padding-top: 44px; }</style>
    <% } %>
    <div class="profile-page">
        <div class="brand-top">
            <span>Link<span class="brand-highlight">TR</span></span>
        </div>

        <% if (merchant.cover_image) { %>
        <div class="cover-image">
            <img src="<%= merchant.cover_image %>" alt="غلاف">
        </div>
        <% } %>

        <div class="profile-card card-<%= merchant.card_style || 'default' %>">
            <div class="profile-avatar">
                <% if (merchant.profile_image) { %>
                    <img src="<%= merchant.profile_image %>" alt="<%= merchant.store_name %>">
                <% } else { %>
                    <div class="avatar-placeholder">
                        <i class="fas fa-store"></i>
                    </div>
                <% } %>
            </div>
            <h1 class="profile-name" id="profile-store-name">
                <% if (merchant.is_verified) { %><i class="fas fa-check-circle verified-icon"></i> <% } %>
                <%= merchant.store_name %>
            </h1>
            <% if (merchant.store_desc) { %>
                <p class="profile-desc" id="profile-store-desc">
                    <%= merchant.store_desc %>
                </p>
            <% } %>

            <div class="profile-actions">
                <button class="share-btn" onclick="shareProfile()"><i class="fas fa-share-alt"></i> مشاركة</button>
                <button class="lang-toggle-btn" id="lang-toggle" onclick="translatePage()" style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:inherit;padding:6px 14px;border-radius:20px;cursor:pointer;font-size:13px;font-weight:600;letter-spacing:1px">EN</button>
                <span class="view-count"><i class="fas fa-eye"></i> <%= viewCount %></span>
            </div>
        </div>

        <% const activeProducts = (products || []).filter(p => p.is_active !== 0); %>
        <% if (activeProducts.length > 0) { %>
        <div class="profile-tabs">
            <button class="profile-tab active" data-tab="links" onclick="switchTab('links', this)"><i class="fas fa-link"></i> الروابط</button>
            <button class="profile-tab" data-tab="products" onclick="switchTab('products', this)"><i class="fas fa-shopping-bag"></i> المنتجات</button>
        </div>
        <% } %>

        <div class="tab-content" id="tab-links">
        <div class="links-container">
            <% const activeLinks = links.filter(l => l.is_active); %>
            <% activeLinks.forEach(link => { %>
                <%- include('partials/profile-link', { link, merchant }) %>
            <% }) %>
        </div>
        </div><!-- end tab-links -->

        <div class="tab-content" id="tab-products" style="display:none">
            <% const productCategories = [...new Set(activeProducts.map(p => p.category).filter(c => c))]; %>
            <% const uncategorized = activeProducts.filter(p => !p.category); %>

            <!-- Categories View -->
            <div id="categories-view">
                <% if (productCategories.length > 0) { %>
                <div class="categories-grid">
                    <% productCategories.forEach((cat, idx) => { %>
                    <% const catProducts = activeProducts.filter(p => p.category === cat); %>
                    <% const catImage = catProducts.find(p => p.image); %>
                    <div class="category-card" onclick="openCategory(this.dataset.catName)" data-cat-idx="<%= idx %>">
                        <div class="category-card-img">
                            <% if (catImage && catImage.image) { %>
                                <img src="<%= catImage.image %>" alt="" loading="lazy">
                            <% } else { %>
                                <div class="category-card-placeholder"><i class="fas fa-box-open"></i></div>
                            <% } %>
                            <div class="category-card-overlay"></div>
                        </div>
                        <div class="category-card-info">
                            <h3 class="category-name"><%= cat %></h3>
                            <span class="category-count"><%= catProducts.length %> منتج</span>
                        </div>
                    </div>
                    <% }) %>

                    <% if (uncategorized.length > 0) { %>
                    <div class="category-card" onclick="openCategory('__uncategorized__')">
                        <div class="category-card-img">
                            <% const uncatImage = uncategorized.find(p => p.image); %>
                            <% if (uncatImage && uncatImage.image) { %>
                                <img src="<%= uncatImage.image %>" alt="" loading="lazy">
                            <% } else { %>
                                <div class="category-card-placeholder"><i class="fas fa-th-large"></i></div>
                            <% } %>
                            <div class="category-card-overlay"></div>
                        </div>
                        <div class="category-card-info">
                            <h3 class="category-name">أخرى</h3>
                            <span class="category-count"><%= uncategorized.length %> منتج</span>
                        </div>
                    </div>
                    <% } %>
                </div>
                <% } else { %>
                <!-- No categories - show all products directly -->
                <div class="products-grid">
                    <% activeProducts.forEach(product => { %>
                    <%- include('partials/product-card', { product, merchant }) %>
                    <% }) %>
                </div>
                <% } %>
            </div>

            <!-- Category Products View (hidden by default) -->
            <div id="category-products-view" style="display:none">
                <button class="category-back-btn" onclick="backToCategories()">
                    <i class="fas fa-arrow-right"></i> رجوع للأقسام
                </button>
                <h3 class="category-title" id="category-title-text"></h3>
                <div class="products-grid" id="category-products-grid"></div>
            </div>

            <!-- Hidden product cards for JS to clone -->
            <div style="display:none" id="all-products-data">
                <% activeProducts.forEach(product => { %>
                <div class="product-template" data-category="<%= product.category || '' %>"
                    data-title="<%= product.title %>"
                    data-description="<%= product.description || '' %>"
                    data-price="<%= product.price %>"
                    data-old-price="<%= product.old_price || 0 %>"
                    data-image="<%= product.image || '' %>"
                    data-salla-store="<%= product.salla_store_id || '' %>"
                    data-salla-product="<%= product.salla_product_id || '' %>"
                    data-salla-label="<%= product.salla_label || 'اشتري الآن' %>"
                    data-salla-url="<%= product.salla_url || '' %>"
                    data-card-style="<%= merchant.card_style || 'default' %>">
                </div>
                <% }) %>
            </div>
        </div><!-- end tab-products -->

        <!-- Product Preview Modal -->
        <div class="product-preview-overlay" id="product-preview-modal" onclick="if(event.target===this)closeProductPreview()">
            <div class="product-preview-modal">
                <button class="product-preview-close" onclick="closeProductPreview()"><i class="fas fa-times"></i></button>
                <div class="product-preview-image" id="pp-image"></div>
                <div class="product-preview-body">
                    <h2 id="pp-title"></h2>
                    <p id="pp-description"></p>
                    <div class="product-preview-pricing">
                        <span class="product-current-price" id="pp-price"></span>
                        <span class="product-was-price" id="pp-old-price"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="powered-by">
            <a href="/">Link<span style="color:#8B5CF6">TR</span></a>
        </div>
    </div>

    <script>
    // Apply button backgrounds
    document.querySelectorAll('[data-bg]').forEach(el => {
        const bg = el.dataset.bg;
        if (bg) el.style.background = bg;
    });
    document.querySelectorAll('[data-gradient]').forEach(el => {
        const g = el.dataset.gradient;
        if (g) el.style.background = g;
    });

    // Countdown timers
    document.querySelectorAll('[data-countdown]').forEach(el => {
        const target = new Date(el.dataset.countdown).getTime();
        if (isNaN(target)) return;
        const tick = () => {
            const now = Date.now();
            const diff = target - now;
            if (diff <= 0) { el.textContent = 'انتهى'; return; }
            const d = Math.floor(diff / 86400000);
            const h = Math.floor((diff % 86400000) / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            el.textContent = (d > 0 ? d + 'ي ' : '') + h + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
        };
        tick();
        setInterval(tick, 1000);
    });

    // Share
    function shareProfile() {
        const url = window.location.href;
        const title = document.title;
        if (navigator.share) {
            navigator.share({ title, url });
        } else {
            navigator.clipboard.writeText(url).then(() => {
                const btn = document.querySelector('.share-btn');
                btn.innerHTML = '<i class="fas fa-check"></i> تم النسخ';
                setTimeout(() => btn.innerHTML = '<i class="fas fa-share-alt"></i> مشاركة', 2000);
            });
        }
    }

    // Track clicks
    document.querySelectorAll('.profile-link').forEach(el => {
        el.addEventListener('click', () => {
            const id = el.dataset.linkId;
            if (id) fetch('/api/links/click/' + id, { method: 'POST' }).catch(() => {});
        });
    });

    // Tab switching
    function switchTab(tab, btn) {
        document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
        document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('active'));
        const target = document.getElementById('tab-' + tab);
        if (target) target.style.display = '';
        if (btn) btn.classList.add('active');
    }

    // Product category filter
    (function() {
        // Set category names safely via JS
        var _cats = <%- JSON.stringify(productCategories || []) %>;
        _cats.forEach(function(cat, idx) {
            var el = document.querySelector('[data-cat-idx="' + idx + '"]');
            if (el) el.dataset.catName = cat;
        });
    })();

    function openCategory(catName) {
        const categoriesView = document.getElementById('categories-view');
        const productsView = document.getElementById('category-products-view');
        const grid = document.getElementById('category-products-grid');
        const titleEl = document.getElementById('category-title-text');

        titleEl.textContent = catName === '__uncategorized__' ? 'أخرى' : catName;
        grid.innerHTML = '';

        // Get products for this category
        document.querySelectorAll('#all-products-data .product-template').forEach(tpl => {
            const pCat = tpl.dataset.category;
            if ((catName === '__uncategorized__' && !pCat) || pCat === catName) {
                const card = buildProductCard(tpl);
                grid.appendChild(card);
            }
        });

        categoriesView.style.display = 'none';
        productsView.style.display = '';
        productsView.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function backToCategories() {
        document.getElementById('category-products-view').style.display = 'none';
        document.getElementById('categories-view').style.display = '';
    }

    function buildProductCard(tpl) {
        const d = tpl.dataset;
        const card = document.createElement('div');
        card.className = 'product-item card-' + d.cardStyle;

        let html = '';
        const price = parseFloat(d.price) || 0;
        const oldPrice = parseFloat(d.oldPrice) || 0;

        if (oldPrice > 0 && oldPrice > price) {
            html += '<span class="product-discount-badge">' + Math.round((1 - price / oldPrice) * 100) + '%-</span>';
        }

        html += '<button class="product-preview-btn" onclick="openProductPreview(this)" title="معاينة"'
            + ' data-title="' + escHtml(d.title) + '"'
            + ' data-description="' + escHtml(d.description) + '"'
            + ' data-price="' + d.price + '"'
            + ' data-old-price="' + d.oldPrice + '"'
            + ' data-image="' + escHtml(d.image) + '">'
            + '<i class="fas fa-eye"></i></button>';

        html += '<div class="product-image">';
        if (d.image) {
            html += '<img src="' + escHtml(d.image) + '" alt="' + escHtml(d.title) + '" loading="lazy">';
        } else {
            html += '<div class="product-image-placeholder"><i class="fas fa-image"></i></div>';
        }
        html += '</div>';

        html += '<div class="product-details">';
        html += '<h3 class="product-title">' + escHtml(d.title) + '</h3>';
        if (d.description) html += '<p class="product-description">' + escHtml(d.description) + '</p>';
        html += '<div class="product-pricing"><span class="product-current-price">' + price + ' ر.س</span>';
        if (oldPrice > 0) html += '<span class="product-was-price">' + oldPrice + ' ر.س</span>';
        html += '</div>';

        if (d.sallaStore && d.sallaProduct) {
            html += '<div class="salla-widget-wrap"><salla-mini-checkout-widget store-id="' + escHtml(d.sallaStore)
                + '" products="[' + escHtml(d.sallaProduct) + ']" language="ar" label="' + escHtml(d.sallaLabel)
                + '"></salla-mini-checkout-widget></div>';
        } else if (d.sallaUrl) {
            html += '<a href="' + escHtml(d.sallaUrl) + '" target="_blank" rel="noopener noreferrer" class="product-buy-btn">'
                + '<i class="fas fa-shopping-cart"></i> اشتري الآن</a>';
        }
        html += '</div>';

        card.innerHTML = html;
        return card;
    }

    function escHtml(s) {
        if (!s) return '';
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Product preview modal
    function openProductPreview(btn) {
        const modal = document.getElementById('product-preview-modal');
        document.getElementById('pp-title').textContent = btn.dataset.title;
        document.getElementById('pp-description').textContent = btn.dataset.description;
        document.getElementById('pp-price').textContent = btn.dataset.price + ' ر.س';
        const oldPrice = parseFloat(btn.dataset.oldPrice);
        const ppOld = document.getElementById('pp-old-price');
        if (oldPrice > 0) {
            ppOld.textContent = oldPrice + ' ر.س';
            ppOld.style.display = '';
        } else {
            ppOld.style.display = 'none';
        }
        const imgDiv = document.getElementById('pp-image');
        imgDiv.innerHTML = '';
        if (btn.dataset.image) {
            const img = document.createElement('img');
            img.src = btn.dataset.image;
            img.alt = '';
            imgDiv.appendChild(img);
        } else {
            imgDiv.innerHTML = '<div class="product-image-placeholder"><i class="fas fa-image"></i></div>';
        }
        modal.classList.add('show');
        document.body.style.overflow = 'hidden';
    }
    function closeProductPreview() {
        document.getElementById('product-preview-modal').classList.remove('show');
        document.body.style.overflow = '';
    }

    // Auto-translate (AR ↔ EN)
    (function() {
        let isEnglish = false;
        const originalTexts = new Map();
        const translatedCache = new Map();
        let translating = false;

        function getTextElements() {
            return document.querySelectorAll(
                '.profile-name, .profile-desc, .section-header-row span, ' +
                '.link-title, .link-desc, .link-badge, ' +
                '.product-title, .product-description, .product-buy-btn, ' +
                '.share-btn, .profile-tab, .filter-btn'
            );
        }

        async function translateOne(text) {
            if (translatedCache.has(text)) return translatedCache.get(text);
            try {
                const res = await fetch('https://translate.googleapis.com/translate_a/single?client=gtx&sl=ar&tl=en&dt=t&q=' + encodeURIComponent(text));
                const data = await res.json();
                const translated = data[0].map(s => s[0]).join('');
                translatedCache.set(text, translated);
                return translated;
            } catch(e) {
                return text;
            }
        }

        async function translateBatch(texts) {
            // Join all texts with newline separator, translate as one request, then split
            const separator = '\n\n';
            const joined = texts.join(separator);
            try {
                const res = await fetch('https://translate.googleapis.com/translate_a/single?client=gtx&sl=ar&tl=en&dt=t&q=' + encodeURIComponent(joined));
                const data = await res.json();
                const fullTranslation = data[0].map(s => s[0]).join('');
                const parts = fullTranslation.split(/\n\n/);
                texts.forEach((text, i) => {
                    translatedCache.set(text, (parts[i] || text).trim());
                });
            } catch(e) {
                // Fallback: translate one by one
                for (const text of texts) {
                    await translateOne(text);
                }
            }
        }

        window.translatePage = async function() {
            if (translating) return;
            const btn = document.getElementById('lang-toggle');
            const elements = getTextElements();

            if (isEnglish) {
                // Restore Arabic
                elements.forEach(el => {
                    if (originalTexts.has(el)) {
                        const icon = el.querySelector('i');
                        el.textContent = originalTexts.get(el);
                        if (icon) el.prepend(icon, ' ');
                        el.removeAttribute('dir');
                        el.style.textAlign = '';
                    }
                });
                document.body.classList.remove('translated-en');
                btn.textContent = 'EN';
                isEnglish = false;
                return;
            }

            // Translate to English
            translating = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            // Collect unique texts that need translation
            const textsToTranslate = [];
            elements.forEach(el => {
                const text = el.textContent.trim();
                if (text) {
                    if (!originalTexts.has(el)) originalTexts.set(el, text);
                    if (!translatedCache.has(text) && !textsToTranslate.includes(text)) {
                        textsToTranslate.push(text);
                    }
                }
            });

            // Translate in batches of 15  
            for (let i = 0; i < textsToTranslate.length; i += 15) {
                const batch = textsToTranslate.slice(i, i + 15);
                await translateBatch(batch);
            }

            // Apply translations
            elements.forEach(el => {
                const origText = originalTexts.get(el);
                if (origText && translatedCache.has(origText)) {
                    const icon = el.querySelector('i');
                    el.textContent = translatedCache.get(origText);
                    if (icon) el.prepend(icon, ' ');
                    el.setAttribute('dir', 'ltr');
                    el.style.textAlign = 'center';
                }
            });

            document.body.classList.add('translated-en');
            btn.textContent = 'ع';
            isEnglish = true;
            translating = false;
        };
    })();
    </script>
</body>
</html>
