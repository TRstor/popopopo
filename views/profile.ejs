<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= merchant.store_name %></title>
    <meta name="description" content="<%= merchant.store_desc || merchant.store_name %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Cairo:wght@400;600;700;800&family=Almarai:wght@400;700;800&family=Changa:wght@400;600;700;800&family=Readex+Pro:wght@400;600;700&family=Noto+Kufi+Arabic:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/theme-<%= merchant.theme_style || 'dark' %>.css">
    <style>
        body { font-family: '<%= merchant.font_family || "Tajawal" %>', sans-serif; }
        <% if (merchant.font_size === 'small') { %>
        .profile-name { font-size: 17px; }
        .profile-desc { font-size: 12px; }
        .profile-link span { font-size: 12px; }
        <% } else if (merchant.font_size === 'large') { %>
        .profile-name { font-size: 24px; }
        .profile-desc { font-size: 15px; }
        .profile-link span { font-size: 16px; }
        <% } %>
        <% if (merchant.bg_image) { %>
        body { background-image: url('<%= merchant.bg_image %>'); background-size: cover; background-position: center; background-attachment: fixed; }
        body::before { content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 0; }
        .profile-page { position: relative; z-index: 1; }
        <% } %>
    </style>
</head>
<body>
    <div class="profile-page">
        <div class="brand-top">
            <span>Link<span class="brand-highlight">in1</span></span>
        </div>

        <% if (merchant.cover_image) { %>
        <div class="cover-image">
            <img src="<%= merchant.cover_image %>" alt="غلاف">
        </div>
        <% } %>

        <div class="profile-card card-<%= merchant.card_style || 'default' %>">
            <div class="profile-avatar">
                <% if (merchant.profile_image) { %>
                    <img src="<%= merchant.profile_image %>" alt="<%= merchant.store_name %>">
                <% } else { %>
                    <div class="avatar-placeholder">
                        <i class="fas fa-store"></i>
                    </div>
                <% } %>
            </div>
            <h1 class="profile-name">
                <% if (merchant.is_verified) { %><i class="fas fa-check-circle verified-icon"></i> <% } %>
                <%= merchant.store_name %>
            </h1>
            <% if (merchant.store_desc) { %>
                <p class="profile-desc"><%= merchant.store_desc %></p>
            <% } %>

            <div class="profile-actions">
                <button class="share-btn" onclick="shareProfile()"><i class="fas fa-share-alt"></i> مشاركة</button>
                <span class="view-count"><i class="fas fa-eye"></i> <%= viewCount %></span>
            </div>
        </div>

        <% const activeProducts = (products || []).filter(p => p.is_active !== 0); %>
        <% if (activeProducts.length > 0) { %>
        <div class="profile-tabs">
            <button class="profile-tab active" data-tab="links" onclick="switchTab('links', this)"><i class="fas fa-link"></i> الروابط</button>
            <button class="profile-tab" data-tab="products" onclick="switchTab('products', this)"><i class="fas fa-shopping-bag"></i> المنتجات</button>
        </div>
        <% } %>

        <div class="tab-content" id="tab-links">
        <div class="links-container">
            <% 
            const activeSections = sections || [];
            const unsectionedLinks = links.filter(l => l.is_active && (!l.section_id || l.section_id === 0));
            %>

            <% if (unsectionedLinks.length > 0) { %>
                <% unsectionedLinks.forEach(link => { %>
                    <%- include('partials/profile-link', { link, merchant }) %>
                <% }) %>
            <% } %>

            <% activeSections.forEach(section => { %>
                <% const sectionLinks = links.filter(l => l.is_active && l.section_id === section.id); %>
                <% if (sectionLinks.length > 0) { %>
                    <div class="section-header-row"><span><%= section.title %></span></div>
                    <% sectionLinks.forEach(link => { %>
                        <%- include('partials/profile-link', { link, merchant }) %>
                    <% }) %>
                <% } %>
            <% }) %>
        </div>
        </div><!-- end tab-links -->

        <div class="tab-content" id="tab-products" style="display:none">
            <div class="products-grid">
                <% activeProducts.forEach(product => { %>
                <div class="product-item card-<%= merchant.card_style || 'default' %>">
                    <% if (product.old_price > 0 && product.old_price > product.price) { %>
                        <span class="product-discount-badge"><%= Math.round((1 - product.price / product.old_price) * 100) %>%-</span>
                    <% } %>
                    <div class="product-image">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.title %>">
                        <% } else { %>
                            <div class="product-image-placeholder"><i class="fas fa-image"></i></div>
                        <% } %>
                    </div>
                    <div class="product-details">
                        <h3 class="product-title"><%= product.title %></h3>
                        <% if (product.description) { %>
                            <p class="product-description"><%= product.description %></p>
                        <% } %>
                        <div class="product-pricing">
                            <span class="product-current-price"><%= product.price %> ر.س</span>
                            <% if (product.old_price > 0) { %>
                                <span class="product-was-price"><%= product.old_price %> ر.س</span>
                            <% } %>
                        </div>
                        <% if (product.salla_url) { %>
                            <a href="<%= product.salla_url %>" target="_blank" rel="noopener noreferrer" class="product-buy-btn">
                                <i class="fas fa-shopping-cart"></i> اشتري الآن
                            </a>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        </div><!-- end tab-products -->

        <div class="powered-by">
            <a href="/">Linkin1</a>
        </div>
    </div>

    <script>
    // Apply button backgrounds
    document.querySelectorAll('[data-bg]').forEach(el => {
        const bg = el.dataset.bg;
        if (bg) el.style.background = bg;
    });
    document.querySelectorAll('[data-gradient]').forEach(el => {
        const g = el.dataset.gradient;
        if (g) el.style.background = g;
    });

    // Countdown timers
    document.querySelectorAll('[data-countdown]').forEach(el => {
        const target = new Date(el.dataset.countdown).getTime();
        if (isNaN(target)) return;
        const tick = () => {
            const now = Date.now();
            const diff = target - now;
            if (diff <= 0) { el.textContent = 'انتهى'; return; }
            const d = Math.floor(diff / 86400000);
            const h = Math.floor((diff % 86400000) / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            el.textContent = (d > 0 ? d + 'ي ' : '') + h + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
        };
        tick();
        setInterval(tick, 1000);
    });

    // Share
    function shareProfile() {
        const url = window.location.href;
        const title = document.title;
        if (navigator.share) {
            navigator.share({ title, url });
        } else {
            navigator.clipboard.writeText(url).then(() => {
                const btn = document.querySelector('.share-btn');
                btn.innerHTML = '<i class="fas fa-check"></i> تم النسخ';
                setTimeout(() => btn.innerHTML = '<i class="fas fa-share-alt"></i> مشاركة', 2000);
            });
        }
    }

    // Track clicks
    document.querySelectorAll('.profile-link').forEach(el => {
        el.addEventListener('click', () => {
            const id = el.dataset.linkId;
            if (id) fetch('/api/links/click/' + id, { method: 'POST' }).catch(() => {});
        });
    });

    // Tab switching
    function switchTab(tab, btn) {
        document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
        document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('active'));
        const target = document.getElementById('tab-' + tab);
        if (target) target.style.display = '';
        if (btn) btn.classList.add('active');
    }
    </script>
</body>
</html>
