<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم - Linkin1</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="dashboard-layout">
        <div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <span><i class="fas fa-link"></i> Linkin1</span>
                <button class="sidebar-close" onclick="closeSidebar()"><i class="fas fa-times"></i></button>
            </div>
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-item active" data-section="links-section" onclick="showSection('links-section', this)">
                    <i class="fas fa-th-large"></i> الروابط
                </a>
                <a href="#" class="nav-item" data-section="products-section" onclick="showSection('products-section', this)">
                    <i class="fas fa-shopping-bag"></i> المنتجات
                </a>
                <a href="#" class="nav-item" data-section="sections-section" onclick="showSection('sections-section', this)">
                    <i class="fas fa-layer-group"></i> الأقسام
                </a>
                <a href="#" class="nav-item" data-section="settings-section" onclick="showSection('settings-section', this)">
                    <i class="fas fa-cog"></i> الإعدادات
                </a>
                <a href="#" class="nav-item" data-section="tickets-section" onclick="showSection('tickets-section', this)">
                    <i class="fas fa-headset"></i> الدعم الفني
                </a>
                <% if (notifications && notifications.length > 0) { %>
                <a href="#" class="nav-item" data-section="notif-section" onclick="showSection('notif-section', this)">
                    <i class="fas fa-bell"></i> الإشعارات
                    <span class="nav-badge"><%= notifications.length %></span>
                </a>
                <% } %>
                <a href="/<%= merchant.username %>" target="_blank" class="nav-item">
                    <i class="fas fa-external-link-alt"></i> معاينة الصفحة
                </a>
                <% if (merchant.is_admin) { %>
                <a href="/admin" class="nav-item admin-link">
                    <i class="fas fa-shield-alt"></i> لوحة الإدارة
                </a>
                <% } %>
            </nav>
            <div class="sidebar-footer">
                <a href="/logout" class="nav-item logout">
                    <i class="fas fa-sign-out-alt"></i> تسجيل خروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <button class="sidebar-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <h2>مرحباً، <%= merchant.store_name %></h2>
                <div class="topbar-stats">
                    <span class="stat-chip"><i class="fas fa-eye"></i> <%= viewCount %></span>
                    <span class="stat-chip"><i class="fas fa-link"></i> <%= links.length %></span>
                </div>
                <div class="profile-url">
                    <i class="fas fa-link"></i>
                    <span id="profile-url"><%= profileUrl %></span>
                    <button onclick="copyUrl()" class="btn-copy" title="نسخ الرابط">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
            </div>

            <% if (typeof msg !== 'undefined' || (typeof locals !== 'undefined')) { %>
            <% const qmsg = typeof locals !== 'undefined' && locals.msg ? locals.msg : ''; %>
            <% } %>

            <!-- Links Section -->
            <section class="content-section" id="links-section">
                <div class="section-header">
                    <h3><i class="fas fa-th-large"></i> روابطك</h3>
                    <div class="section-actions">
                        <div class="filter-group">
                            <a href="/dashboard?filter=all" class="filter-btn <%= filter === 'all' ? 'active' : '' %>">الكل</a>
                            <a href="/dashboard?filter=active" class="filter-btn <%= filter === 'active' ? 'active' : '' %>">نشط</a>
                            <a href="/dashboard?filter=inactive" class="filter-btn <%= filter === 'inactive' ? 'active' : '' %>">معطل</a>
                        </div>
                        <button class="btn btn-primary btn-sm" onclick="openAddModal()">
                            <i class="fas fa-plus"></i> إضافة رابط
                        </button>
                    </div>
                </div>

                <div class="links-list" id="links-list">
                    <% 
                    let filteredLinks = links;
                    if (filter === 'active') filteredLinks = links.filter(l => l.is_active);
                    else if (filter === 'inactive') filteredLinks = links.filter(l => !l.is_active);
                    %>
                    <% if (filteredLinks.length === 0) { %>
                        <div class="empty-state">
                            <i class="fas fa-link"></i>
                            <p>لم تضف أي روابط بعد</p>
                            <button class="btn btn-primary" onclick="openAddModal()">أضف رابطك الأول</button>
                        </div>
                    <% } else { %>
                        <% filteredLinks.forEach((link, index) => { %>
                            <div class="link-card" data-id="<%= link.id %>" data-size="<%= link.size || 'full' %>" draggable="true">
                                <div class="drag-handle">
                                    <i class="fas fa-grip-vertical"></i>
                                </div>
                                <div class="link-icon" data-bg="<%= link.color %>">
                                    <i class="<%= link.icon %>"></i>
                                </div>
                                <div class="link-info">
                                    <strong>
                                        <%= link.title %>
                                        <% if (link.badge) { %><span class="mini-badge"><%= link.badge %></span><% } %>
                                    </strong>
                                    <small><%= link.url %></small>
                                    <% if (link.description) { %><small class="link-desc-preview"><%= link.description %></small><% } %>
                                </div>
                                <span class="link-size-badge"><%= link.size === 'third' ? '⅓' : link.size === 'half' ? '½' : '1' %></span>
                                <div class="link-actions">
                                    <form method="POST" action="/dashboard/links/toggle/<%= link.id %>" style="display:inline">
                                        <button type="submit" class="btn-icon <%= link.is_active ? 'active' : 'inactive' %>" title="<%= link.is_active ? 'مفعل' : 'معطل' %>">
                                            <i class="fas fa-<%= link.is_active ? 'eye' : 'eye-slash' %>"></i>
                                        </button>
                                    </form>
                                    <form method="POST" action="/dashboard/links/duplicate/<%= link.id %>" style="display:inline">
                                        <button type="submit" class="btn-icon" title="تكرار">
                                            <i class="fas fa-copy"></i>
                                        </button>
                                    </form>
                                    <button class="btn-icon edit" data-link='<%- JSON.stringify(link) %>' onclick="openEditModal(JSON.parse(this.dataset.link))" title="تعديل">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <form method="POST" action="/dashboard/links/delete/<%= link.id %>" style="display:inline" onsubmit="return confirm('هل أنت متأكد من الحذف؟')">
                                        <button type="submit" class="btn-icon delete" title="حذف">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </section>

            <!-- Products Section -->
            <section class="content-section hidden" id="products-section">
                <div class="section-header">
                    <h3><i class="fas fa-shopping-bag"></i> منتجاتك</h3>
                    <div class="section-actions">
                        <button class="btn btn-primary btn-sm" onclick="openModal('add-product-modal')">
                            <i class="fas fa-plus"></i> إضافة منتج
                        </button>
                    </div>
                </div>

                <div class="products-list" id="products-list">
                    <% if (!products || products.length === 0) { %>
                        <div class="empty-state">
                            <i class="fas fa-shopping-bag"></i>
                            <p>لم تضف أي منتجات بعد</p>
                            <button class="btn btn-primary" onclick="openModal('add-product-modal')">أضف منتجك الأول</button>
                        </div>
                    <% } else { %>
                        <% products.forEach((product, index) => { %>
                            <div class="product-card" data-id="<%= product.id %>" draggable="true">
                                <div class="drag-handle">
                                    <i class="fas fa-grip-vertical"></i>
                                </div>
                                <div class="product-thumb">
                                    <% if (product.image) { %>
                                        <img src="<%= product.image %>" alt="<%= product.title %>">
                                    <% } else { %>
                                        <i class="fas fa-image"></i>
                                    <% } %>
                                </div>
                                <div class="product-info">
                                    <strong><%= product.title %></strong>
                                    <div class="product-price-row">
                                        <span class="product-price"><%= product.price %> ر.س</span>
                                        <% if (product.old_price > 0) { %>
                                            <span class="product-old-price"><%= product.old_price %> ر.س</span>
                                        <% } %>
                                    </div>
                                    <% if (product.category) { %><span class="product-category-badge"><i class="fas fa-tag"></i> <%= product.category %></span><% } %>
                                    <% if (product.description) { %><small class="product-desc-preview"><%= product.description %></small><% } %>
                                </div>
                                <div class="link-actions">
                                    <form method="POST" action="/dashboard/products/toggle/<%= product.id %>" style="display:inline">
                                        <button type="submit" class="btn-icon <%= product.is_active ? 'active' : 'inactive' %>" title="<%= product.is_active ? 'مفعل' : 'معطل' %>">
                                            <i class="fas fa-<%= product.is_active ? 'eye' : 'eye-slash' %>"></i>
                                        </button>
                                    </form>
                                    <button class="btn-icon edit" data-product='<%- JSON.stringify(product) %>' onclick="openEditProductModal(JSON.parse(this.dataset.product))" title="تعديل">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <form method="POST" action="/dashboard/products/delete/<%= product.id %>" style="display:inline" onsubmit="return confirm('هل أنت متأكد من حذف المنتج؟')">
                                        <button type="submit" class="btn-icon delete" title="حذف">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </section>

            <!-- Sections Section -->
            <section class="content-section hidden" id="sections-section">
                <div class="section-header">
                    <h3><i class="fas fa-layer-group"></i> أقسام الروابط</h3>
                </div>
                <p class="section-desc">أنشئ أقسام لتنظيم روابطك في مجموعات</p>
                <form method="POST" action="/dashboard/sections/add" class="inline-form">
                    <input type="text" name="title" placeholder="اسم القسم الجديد" required>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> إضافة</button>
                </form>
                <div class="sections-list">
                    <% if (sections.length === 0) { %>
                        <p class="empty-hint">لا توجد أقسام بعد</p>
                    <% } else { %>
                        <% sections.forEach(s => { %>
                        <div class="section-item">
                            <span><i class="fas fa-folder"></i> <%= s.title %></span>
                            <form method="POST" action="/dashboard/sections/delete/<%= s.id %>" style="display:inline" onsubmit="return confirm('حذف القسم؟ الروابط لن تُحذف')">
                                <button type="submit" class="btn-icon delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                        <% }) %>
                    <% } %>
                </div>
            </section>

            <!-- Settings Section -->
            <section class="content-section hidden" id="settings-section">
                <div class="section-header">
                    <h3><i class="fas fa-cog"></i> إعدادات المتجر</h3>
                </div>

                <form method="POST" action="/dashboard/settings" enctype="multipart/form-data" class="settings-form">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>صورة البروفايل</label>
                            <div class="profile-upload">
                                <% if (merchant.profile_image) { %>
                                    <img src="<%= merchant.profile_image %>" alt="Profile" class="current-avatar">
                                <% } else { %>
                                    <div class="avatar-placeholder"><i class="fas fa-user"></i></div>
                                <% } %>
                                <input type="file" name="profile_image" accept="image/*">
                            </div>
                        </div>
                        <div class="form-group">
                            <label>صورة الغلاف</label>
                            <div class="profile-upload">
                                <% if (merchant.cover_image) { %>
                                    <img src="<%= merchant.cover_image %>" alt="Cover" class="current-avatar" style="border-radius:8px;width:100px;height:50px">
                                <% } else { %>
                                    <div class="avatar-placeholder" style="border-radius:8px;width:100px;height:50px;font-size:16px"><i class="fas fa-image"></i></div>
                                <% } %>
                                <input type="file" name="cover_image" accept="image/*">
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>اسم المتجر</label>
                        <input type="text" name="store_name" value="<%= merchant.store_name %>" required>
                    </div>

                    <div class="form-group">
                        <label>وصف المتجر</label>
                        <textarea name="store_desc" rows="3" placeholder="اكتب وصفاً مختصراً لمتجرك"><%= merchant.store_desc || '' %></textarea>
                    </div>

                    <div class="form-group">
                        <label>اللون الرئيسي</label>
                        <div class="color-row">
                            <input type="color" name="theme_color" value="<%= merchant.theme_color || '#8B5CF6' %>">
                            <div class="preset-colors">
                                <button type="button" class="color-dot" data-color="#8B5CF6" style="background:#8B5CF6"></button>
                                <button type="button" class="color-dot" data-color="#3b82f6" style="background:#3b82f6"></button>
                                <button type="button" class="color-dot" data-color="#10b981" style="background:#10b981"></button>
                                <button type="button" class="color-dot" data-color="#f59e0b" style="background:#f59e0b"></button>
                                <button type="button" class="color-dot" data-color="#ef4444" style="background:#ef4444"></button>
                                <button type="button" class="color-dot" data-color="#ec4899" style="background:#ec4899"></button>
                                <button type="button" class="color-dot" data-color="#06b6d4" style="background:#06b6d4"></button>
                                <button type="button" class="color-dot" data-color="#f97316" style="background:#f97316"></button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>اختر تصميم جاهز</label>
                        <p class="form-hint">اختر تصميم وسيتم تطبيق الثيم والأزرار والترتيب تلقائياً</p>
                        <div class="design-presets">
                            <!-- Preset 1: Classic Dark -->
                            <div class="design-preset" data-preset="1">
                                <button type="button" class="preset-eye" onclick="previewPreset(1)" title="معاينة"><i class="fas fa-eye"></i></button>
                                <div class="preset-device" style="background:#0a0a0a" onclick="applyPreset(1, this.parentElement.parentElement)">
                                    <div class="pd-notch"></div>
                                    <div class="pd-avatar" style="background:#8B5CF6"></div>
                                    <div class="pd-name" style="background:rgba(255,255,255,0.7)"></div>
                                    <div class="pd-buttons">
                                        <div class="pd-btn" style="background:#8B5CF6;border-radius:10px"></div>
                                        <div class="pd-btn" style="background:#25D366;border-radius:10px"></div>
                                        <div class="pd-btn-row">
                                            <div class="pd-btn-half" style="background:#E1306C;border-radius:10px"></div>
                                            <div class="pd-btn-half" style="background:#1DA1F2;border-radius:10px"></div>
                                        </div>
                                        <div class="pd-btn" style="background:#6D28D9;border-radius:10px"></div>
                                    </div>
                                </div>
                                <span class="preset-label">كلاسيكي</span>
                            </div>
                            <!-- Preset 2: Modern Light -->
                            <div class="design-preset" data-preset="2">
                                <button type="button" class="preset-eye" onclick="previewPreset(2)" title="معاينة"><i class="fas fa-eye"></i></button>
                                <div class="preset-device" style="background:#f5f5f7" onclick="applyPreset(2, this.parentElement)">
                                    <div class="pd-notch" style="background:rgba(0,0,0,0.1)"></div>
                                    <div class="pd-avatar" style="background:#3b82f6"></div>
                                    <div class="pd-name" style="background:rgba(0,0,0,0.5)"></div>
                                    <div class="pd-buttons">
                                        <div class="pd-btn" style="background:#3b82f6;border-radius:20px"></div>
                                        <div class="pd-btn" style="background:#10b981;border-radius:20px"></div>
                                        <div class="pd-btn" style="background:#f59e0b;border-radius:20px"></div>
                                        <div class="pd-btn" style="background:#ec4899;border-radius:20px"></div>
                                    </div>
                                </div>
                                <span class="preset-label">عصري</span>
                            </div>
                            <!-- Preset 3: Elegant Ocean -->
                            <div class="design-preset" data-preset="3">
                                <button type="button" class="preset-eye" onclick="previewPreset(3)" title="معاينة"><i class="fas fa-eye"></i></button>
                                <div class="preset-device" style="background:linear-gradient(135deg,#0c4a6e,#164e63)" onclick="applyPreset(3, this.parentElement)">
                                    <div class="pd-notch" style="background:rgba(255,255,255,0.15)"></div>
                                    <div class="pd-avatar" style="background:#06b6d4"></div>
                                    <div class="pd-name" style="background:rgba(255,255,255,0.6)"></div>
                                    <div class="pd-buttons">
                                        <div class="pd-btn" style="background:#06b6d4;border-radius:4px"></div>
                                        <div class="pd-btn-row">
                                            <div class="pd-btn-half" style="background:#0ea5e9;border-radius:4px"></div>
                                            <div class="pd-btn-half" style="background:#22d3ee;border-radius:4px"></div>
                                        </div>
                                        <div class="pd-btn" style="background:#0284c7;border-radius:4px"></div>
                                        <div class="pd-btn" style="background:#67e8f9;border-radius:4px"></div>
                                    </div>
                                </div>
                                <span class="preset-label">أنيق</span>
                            </div>
                            <!-- Preset 4: Neon -->
                            <div class="design-preset" data-preset="4">
                                <button type="button" class="preset-eye" onclick="previewPreset(4)" title="معاينة"><i class="fas fa-eye"></i></button>
                                <div class="preset-device" style="background:#0f172a" onclick="applyPreset(4, this.parentElement)">
                                    <div class="pd-notch" style="background:rgba(34,211,238,0.3)"></div>
                                    <div class="pd-avatar" style="background:#22d3ee;box-shadow:0 0 8px rgba(34,211,238,0.5)"></div>
                                    <div class="pd-name" style="background:rgba(34,211,238,0.4)"></div>
                                    <div class="pd-buttons">
                                        <div class="pd-btn" style="background:linear-gradient(135deg,#ec4899,#8B5CF6);border-radius:20px"></div>
                                        <div class="pd-btn-row">
                                            <div class="pd-btn-half" style="background:#22d3ee;border-radius:20px"></div>
                                            <div class="pd-btn-half" style="background:#a3e635;border-radius:20px"></div>
                                        </div>
                                        <div class="pd-btn" style="background:linear-gradient(135deg,#10b981,#22d3ee);border-radius:20px"></div>
                                    </div>
                                </div>
                                <span class="preset-label">نيون</span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>ثيم الألوان</label>
                        <div class="extra-themes-row">
                            <% const extraThemes = [
                                {v:'dark',n:'داكن'},{v:'light',n:'فاتح'},{v:'blue',n:'أزرق'},{v:'pink',n:'وردي'},
                                {v:'emerald',n:'زمردي'},{v:'sunset',n:'غروب'},{v:'ocean',n:'محيط'},{v:'rose',n:'روز'},
                                {v:'midnight',n:'ليلي'},{v:'coffee',n:'قهوة'},{v:'forest',n:'غابة'},{v:'lavender',n:'لافندر'},
                                {v:'cherry',n:'كرزي'},{v:'arctic',n:'قطبي'}
                            ]; %>
                            <% extraThemes.forEach(t => { %>
                            <label class="theme-option">
                                <input type="radio" name="theme_style" value="<%= t.v %>" <%= (merchant.theme_style || 'dark') === t.v ? 'checked' : '' %>>
                                <div class="theme-preview theme-<%= t.v %>">
                                    <div class="tp-circle"></div>
                                    <div class="tp-line"></div>
                                    <div class="tp-line short"></div>
                                    <span><%= t.n %></span>
                                </div>
                            </label>
                            <% }) %>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>شكل الأزرار</label>
                        <div class="shape-picker">
                            <% const shapes = [{v:'rounded',n:'مستدير',icon:'⬜'},{v:'square',n:'مربع',icon:'◻️'},{v:'pill',n:'كبسولة',icon:'💊'},{v:'circle',n:'دائري',icon:'⭕'}]; %>
                            <% shapes.forEach(s => { %>
                            <label class="shape-option">
                                <input type="radio" name="button_shape" value="<%= s.v %>" <%= (merchant.button_shape||'rounded')===s.v?'checked':'' %>>
                                <div class="shape-preview"><span><%= s.icon %></span><small><%= s.n %></small></div>
                            </label>
                            <% }) %>
                        </div>
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label>الخط</label>
                            <select name="font_family">
                                <% ['Tajawal','Cairo','Almarai','Changa','Readex Pro','Noto Kufi Arabic'].forEach(f => { %>
                                <option value="<%= f %>" <%= (merchant.font_family||'Tajawal')===f?'selected':'' %>><%= f %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>حجم الخط</label>
                            <select name="font_size">
                                <option value="small" <%= merchant.font_size==='small'?'selected':'' %>>صغير</option>
                                <option value="medium" <%= (merchant.font_size||'medium')==='medium'?'selected':'' %>>متوسط</option>
                                <option value="large" <%= merchant.font_size==='large'?'selected':'' %>>كبير</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>شكل الكروت</label>
                        <select name="card_style">
                            <% [{v:'default',n:'افتراضي'},{v:'glass',n:'زجاجي'},{v:'flat',n:'مسطح'},{v:'bordered',n:'محدد'},{v:'shadow',n:'ظل'}].forEach(c => { %>
                            <option value="<%= c.v %>" <%= (merchant.card_style||'default')===c.v?'selected':'' %>><%= c.n %></option>
                            <% }) %>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> حفظ التغييرات
                    </button>
                </form>
            </section>

            <!-- Tickets Section -->
            <section class="content-section hidden" id="tickets-section">
                <div class="section-header">
                    <h3><i class="fas fa-headset"></i> الدعم الفني</h3>
                </div>
                <form method="POST" action="/dashboard/tickets/submit" class="ticket-form">
                    <div class="form-group">
                        <label>الموضوع</label>
                        <input type="text" name="subject" placeholder="موضوع الرسالة" required>
                    </div>
                    <div class="form-group">
                        <label>الرسالة</label>
                        <textarea name="message" rows="4" placeholder="اكتب رسالتك هنا..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-paper-plane"></i> إرسال</button>
                </form>
                <% if (myTickets && myTickets.length > 0) { %>
                <div class="tickets-list">
                    <h4>تذاكرك السابقة</h4>
                    <% myTickets.forEach(t => { %>
                    <div class="ticket-item">
                        <div class="ticket-head">
                            <strong><%= t.subject %></strong>
                            <span class="ticket-status status-<%= t.status %>"><%= t.status === 'open' ? 'مفتوحة' : t.status === 'replied' ? 'تم الرد' : 'مغلقة' %></span>
                        </div>
                        <p><%= t.message %></p>
                        <% if (t.admin_reply) { %><div class="ticket-reply"><i class="fas fa-reply"></i> <%= t.admin_reply %></div><% } %>
                        <small><%= new Date(t.created_at).toLocaleDateString('ar') %></small>
                    </div>
                    <% }) %>
                </div>
                <% } %>
            </section>

            <!-- Notifications Section -->
            <% if (notifications && notifications.length > 0) { %>
            <section class="content-section hidden" id="notif-section">
                <div class="section-header">
                    <h3><i class="fas fa-bell"></i> الإشعارات</h3>
                </div>
                <% notifications.forEach(n => { %>
                <div class="notif-item">
                    <strong><%= n.title %></strong>
                    <p><%= n.message %></p>
                    <small><%= new Date(n.created_at).toLocaleDateString('ar') %></small>
                </div>
                <% }) %>
            </section>
            <% } %>

