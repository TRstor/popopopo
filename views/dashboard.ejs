            <!-- Animated Background Section -->
            <section class="content-section hidden" id="animbg-section">
                <div class="section-header">
                    <h3><i class="fas fa-wand-magic-sparkles"></i> الخلفية المتحركة</h3>
                </div>
                <p style="color:var(--text-muted,#777);font-size:13px;margin-bottom:16px">
                    اختر خلفية متحركة لصفحتك. تعمل فوق الغلاف أو اللون الأساسي وتُضفي حيوية على المتجر.
                </p>
                <form method="POST" action="/dashboard/animated-bg" class="animbg-form" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <label style="display:block;font-weight:700;margin-bottom:10px">نوع الخلفية</label>
                    <div class="animbg-grid">
                        <% const currentAnim = merchant.animated_bg || 'none'; %>
                        <% [
                            {v:'none', n:'بدون', ic:'fa-ban'},
                            {v:'stars', n:'نجوم', ic:'fa-star'},
                            {v:'particles', n:'جزيئات', ic:'fa-circle-dot'},
                            {v:'waves', n:'موجات', ic:'fa-water'},
                            {v:'aurora', n:'شفق', ic:'fa-cloud-moon'},
                            {v:'bubbles', n:'فقاعات', ic:'fa-circle'},
                            {v:'snow', n:'ثلج', ic:'fa-snowflake'},
                            {v:'gradient', n:'تدرّج متحرك', ic:'fa-palette'},
                            {v:'custom', n:'فيديو/GIF مخصّص', ic:'fa-video'}
                        ].forEach(opt => { %>
                        <label class="animbg-option <%= currentAnim === opt.v ? 'selected' : '' %>">
                            <input type="radio" name="animated_bg" value="<%= opt.v %>" <%= currentAnim === opt.v ? 'checked' : '' %>>
                            <div class="animbg-preview animbg-<%= opt.v %>">
                                <i class="fas <%= opt.ic %>"></i>
                            </div>
                            <span><%= opt.n %></span>
                        </label>
                        <% }) %>
                    </div>

                    <div class="form-group" style="margin-top:20px">
                        <label><i class="fas fa-upload"></i> أو ارفع فيديو/صورة من جهازك</label>
                        <input type="file" name="animated_bg_file" accept="video/mp4,video/webm,video/quicktime,image/gif,image/webp,image/jpeg,image/png">
                        <small style="color:var(--text-muted,#777);display:block;margin-top:6px;font-size:12px">
                            الحد الأقصى ~700 كيلوبايت. للفيديوهات الأكبر استخدم رابط خارجي بالأسفل.
                        </small>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-link"></i> أو رابط فيديو MP4 أو GIF</label>
                        <input type="url" name="animated_bg_url" placeholder="https://example.com/bg.mp4"
                            value="<%= merchant.animated_bg_url && !merchant.animated_bg_url.startsWith('/uploads/') ? merchant.animated_bg_url : '' %>">
                        <small style="color:var(--text-muted,#777);display:block;margin-top:6px;font-size:12px">
                            رابط مباشر (.mp4 / .webm / .gif). جرّب <a href="https://giphy.com" target="_blank" style="color:var(--primary,#8B5CF6)">Giphy</a>.
                        </small>
                        <% if (merchant.animated_bg_url && merchant.animated_bg_url.startsWith('/uploads/')) { %>
                        <div style="margin-top:8px;padding:8px 12px;background:rgba(139,92,246,0.1);border-radius:8px;font-size:12px">
                            <i class="fas fa-check-circle" style="color:#22c55e"></i> يوجد ملف مرفوع حالياً
                        </div>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-adjust"></i> شفافية الخلفية</label>
                        <select name="animated_bg_opacity">
                            <% const op = merchant.animated_bg_opacity || '60'; %>
                            <option value="30" <%= op==='30'?'selected':'' %>>خفيفة (30%)</option>
                            <option value="60" <%= op==='60'?'selected':'' %>>متوسطة (60%)</option>
                            <option value="100" <%= op==='100'?'selected':'' %>>كاملة (100%)</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                </form>
                <script>
                    (function(){
                        document.querySelectorAll('.animbg-option input[type="radio"]').forEach(function(r){
                            r.addEventListener('change', function(){
                                document.querySelectorAll('.animbg-option').forEach(function(o){ o.classList.remove('selected'); });
                                r.closest('.animbg-option').classList.add('selected');
                            });
                        });
                        // Auto-select 'custom' when user uploads a file or pastes a URL
                        function selectCustom() {
                            var radio = document.querySelector('.animbg-option input[value="custom"]');
                            if (radio && !radio.checked) {
                                radio.checked = true;
                                radio.dispatchEvent(new Event('change'));
                            }
                        }
                        var fileInput = document.querySelector('input[name="animated_bg_file"]');
                        if (fileInput) fileInput.addEventListener('change', function(){ if (fileInput.files && fileInput.files[0]) selectCustom(); });
                        var urlInput = document.querySelector('input[name="animated_bg_url"]');
                        if (urlInput) urlInput.addEventListener('input', function(){ if (urlInput.value.trim()) selectCustom(); });

                        // Client-side size check to avoid failed uploads
                        var animForm = document.querySelector('.animbg-form');
                        if (animForm) animForm.addEventListener('submit', function(e){
                            if (fileInput && fileInput.files && fileInput.files[0]) {
                                var size = fileInput.files[0].size;
                                if (size > 700 * 1024) {
                                    e.preventDefault();
                                    alert('حجم الملف ' + Math.round(size/1024) + ' كيلوبايت — الحد الأقصى 700 كيلوبايت. استخدم رابط خارجي للملفات الأكبر.');
                                    return false;
                                }
                            }
                        });
                    })();
                </script>
            </section>

