            <div class="modal-header">
                <h3><i class="fas fa-shopping-bag"></i> إضافة منتج</h3>
                <button onclick="closeModal('add-product-modal')" class="modal-close"><i class="fas fa-times"></i></button>
            </div>
            <form method="POST" action="/dashboard/products/add" enctype="multipart/form-data">
                <div class="form-group">
                    <label>اسم المنتج</label>
                    <input type="text" name="title" placeholder="مثال: قميص قطني" required>
                </div>
                <div class="form-group">
                    <label>الوصف (اختياري)</label>
                    <input type="text" name="description" placeholder="وصف قصير للمنتج">
                </div>
                <div class="form-group">
                    <label><i class="fas fa-tag"></i> التصنيف</label>
                    <select name="category">
                        <option value="">بدون تصنيف</option>
                        <% const addCats = [...new Set([...(merchant.product_categories ? JSON.parse(merchant.product_categories) : []), ...(products||[]).map(p => p.category).filter(c => c)])]; %>
                        <% addCats.forEach(cat => { %>
                            <option value="<%= cat %>"><%= cat %></option>
                        <% }) %>
                    </select>
                    <small style="color:#888;display:block;margin-top:4px">أضف تصنيفات جديدة من صفحة "التصنيفات"</small>
                </div>
                <div class="form-group">
                    <label>صورة المنتج</label>
                    <input type="file" name="product_image" accept="image/*">
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label>السعر (ر.س)</label>
                        <input type="number" name="price" step="0.01" min="0" placeholder="99.00" required>
                    </div>
                    <div class="form-group">
                        <label>السعر القديم (اختياري)</label>
                        <input type="number" name="old_price" step="0.01" min="0" placeholder="149.00">
                    </div>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-code"></i> كود ويدجت سلة (الصق الكود هنا)</label>
                    <textarea name="salla_widget_code" rows="4" placeholder="الصق كود ويدجت سلة هنا..." dir="ltr" style="font-size:11px;font-family:monospace;width:100%"></textarea>
                    <small style="color:#888;display:block;margin-top:4px">الصق كود الويدجت من سلة وسيتم استخراج البيانات تلقائياً</small>
                    <div style="background:#fff3cd;color:#856404;border:1px solid #ffc107;border-radius:8px;padding:10px 14px;margin-top:8px;font-size:13px;line-height:1.7">
                        <i class="fas fa-info-circle"></i> <strong>ملاحظة:</strong> عند استخدام ويدجت سلة، سعر الدفع الفعلي هو السعر المسجل داخل منصة سلة وليس السعر المدخل هنا. السعر المدخل أعلاه يُعرض للعرض فقط في صفحة البروفايل.
