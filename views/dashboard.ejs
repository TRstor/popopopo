                        <label>شارة</label>
                        <select id="edit-badge">
                            <option value="">بدون</option>
                            <option value="جديد">جديد</option>
                            <option value="عرض">عرض</option>
                            <option value="🔥">🔥</option>
                            <option value="⭐">⭐</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>نمط الحدود</label>
