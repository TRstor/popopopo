            <section class="preview-panel">
                <h4><i class="fas fa-mobile-alt"></i> معاينة مباشرة</h4>
                <div class="preview-frame">
                    <iframe src="/<%= merchant.username %>" id="preview-iframe"></iframe>
                </div>
            </section>
        </main>
