                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </form>
        </div>
    </div>

    <script>document.querySelectorAll('[data-bg]').forEach(el => el.style.background = el.dataset.bg);</script>

