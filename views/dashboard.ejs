            </form>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
    <script>
    // Auto-inject CSRF token into all POST forms
    (function() {
        const token = document.querySelector('meta[name="csrf-token"]').content;
        document.querySelectorAll('form[method="POST"], form[method="post"]').forEach(form => {
            if (!form.querySelector('input[name="_csrf"]')) {
                const input = document.createElement('input');
                input.type = 'hidden'; input.name = '_csrf'; input.value = token;
                form.prepend(input);
            }
        });
        // Store token globally for fetch calls
        window.csrfToken = token;
    })();

    // Delete cover image (kept outside settings form because nested forms are invalid)
    function deleteCover() {
        if (!confirm('حذف صورة الغلاف؟')) return;
        const body = '_csrf=' + encodeURIComponent(window.csrfToken || '');
        fetch('/dashboard/cover/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': window.csrfToken || '' },
            body: body,
            credentials: 'same-origin'
        }).then(r => {
            if (r.ok || r.redirected) location.reload();
            else r.text().then(t => alert('فشل الحذف: ' + (t || r.status)));
        }).catch(err => alert('فشل الحذف: ' + err.message));
    }

    // Rename category
    var _renameCatForm = null;
    function openRenameCatModal(form, catName) {
        _renameCatForm = form;
        document.getElementById('rename-cat-input').value = catName;
        document.getElementById('rename-cat-old').textContent = catName;
        openModal('rename-cat-modal');
    }
    function submitRenameCat() {
        if (!_renameCatForm) return;
        var newName = document.getElementById('rename-cat-input').value.trim();
        var oldName = _renameCatForm.querySelector('input[name="old_name"]').value;
        if (newName && newName !== oldName) {
            var input = document.createElement('input');
            input.type = 'hidden'; input.name = 'new_name'; input.value = newName;
            _renameCatForm.appendChild(input);
            var csrf = document.createElement('input');
            csrf.type = 'hidden'; csrf.name = '_csrf'; csrf.value = window.csrfToken;
            _renameCatForm.appendChild(csrf);
            _renameCatForm.submit();
        }
        closeModal('rename-cat-modal');
    }

    // Delete category
    var _deleteCatForm = null;
    function openDeleteCatModal(form, catName) {
        _deleteCatForm = form;
        document.getElementById('delete-cat-name').textContent = catName;
        openModal('delete-cat-modal');
    }
    function confirmDeleteCat() {
        if (_deleteCatForm) {
            var csrf = document.createElement('input');
            csrf.type = 'hidden'; csrf.name = '_csrf'; csrf.value = window.csrfToken;
            _deleteCatForm.appendChild(csrf);
            _deleteCatForm.submit();
        }
        closeModal('delete-cat-modal');
    }
    </script>
</body>
</html>
