                <h3><i class="fas fa-pen"></i> تعديل التصنيف</h3>
                <button onclick="closeModal('rename-cat-modal')" class="modal-close"><i class="fas fa-times"></i></button>
            </div>
            <div style="padding:0 0 8px">
