<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إنشاء حساب - TR Store</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <div class="auth-page">
        <div class="auth-card">
            <div class="auth-header">
                <a href="/" class="auth-logo"><i class="fas fa-link"></i> TR Store</a>
                <h2>إنشاء حساب جديد</h2>
                <p>أنشئ حسابك واحصل على صفحة روابط خاصة بك</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
            <% } %>

            <form method="POST" action="/register" class="auth-form">
                <div class="form-group">
                    <label for="store_name"><i class="fas fa-store"></i> اسم المتجر</label>
                    <input type="text" id="store_name" name="store_name" placeholder="مثال: متجر TR" required>
                </div>

                <div class="form-group">
                    <label for="username"><i class="fas fa-at"></i> اسم المستخدم (رابطك الخاص)</label>
                    <input type="text" id="username" name="username" placeholder="مثال: trstore" pattern="[a-zA-Z0-9_-]{3,30}" required autocomplete="username">
                    <small class="form-hint">سيكون رابطك: yoursite.com/<strong id="username-preview">username</strong></small>
                </div>

                <div class="form-group">
                    <label for="email"><i class="fas fa-envelope"></i> البريد الإلكتروني</label>
                    <input type="email" id="email" name="email" placeholder="example@email.com" required autocomplete="email">
                </div>

                <div class="form-group">
                    <label for="password"><i class="fas fa-lock"></i> كلمة المرور</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" minlength="6" required autocomplete="new-password">
                </div>

                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-user-plus"></i> إنشاء الحساب
                </button>
            </form>

            <div class="auth-footer">
                <p>لديك حساب بالفعل؟ <a href="/login">تسجيل الدخول</a></p>
            </div>
        </div>
    </div>

    <script>
        const usernameInput = document.getElementById('username');
        const preview = document.getElementById('username-preview');
        usernameInput.addEventListener('input', () => {
            preview.textContent = usernameInput.value || 'username';
        });
    </script>
</body>
</html>
